{
  "name": "iris",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "react-router typegen && eslint . --max-warnings 0",
    "lint:fix": "react-router typegen && eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:api": "node scripts/retrieve-scheme.ts && openapi-typescript ./app/api/membrane/openapi.json -o ./app/api/membrane/schema.d.ts",
    "prepare": "husky; panda codegen || true",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "@tanstack/react-query": "5.90.21",
    "@types/leaflet": "1.9.21",
    "colorizr": "4.0.1",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "isbot": "5.1.31",
    "leaflet": "1.9.4",
    "openapi-fetch": "0.17.0",
    "openapi-react-query": "0.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "5.0.0",
    "react-router": "7.12.0",
    "type-fest": "5.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.0.1",
    "@cloudflare/vite-plugin": "1.31.2",
    "@eslint/js": "9.39.2",
    "@pandacss/dev": "1.8.1",
    "@react-router/dev": "7.12.0",
    "@storybook/addon-a11y": "10.2.8",
    "@storybook/addon-docs": "10.2.8",
    "@storybook/addon-onboarding": "10.2.8",
    "@storybook/addon-vitest": "10.2.8",
    "@storybook/react-vite": "10.2.8",
    "@tailwindcss/vite": "4.1.13",
    "@types/node": "22",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-storybook": "10.2.8",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "openapi-typescript": "7.13.0",
    "playwright": "1.58.2",
    "prettier": "3.8.0",
    "storybook": "10.2.8",
    "storybook-addon-remix-react-router": "6.0.0",
    "tailwindcss": "4.1.13",
    "typescript": "5.9.2",
    "typescript-eslint": "8.53.0",
    "vite": "7.1.7",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.0.18",
    "wrangler": "4.81.1"
  }
}
