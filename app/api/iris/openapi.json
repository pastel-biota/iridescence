{
  "openapi": "3.1.0",
  "info": {
    "title": "Iris - HTTP Rest API",
    "description": "Iris is a self-host photo album service.\nIris provides the management layer - the frontend service is separated as \"Iridescence\"\n",
    "version": "1.0.0"
  },
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Log in to Iris' user",
        "description": "Issue a new session for Iris to access to the administrative endpoints.\nYou need to create users in advance to log in.",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "The user has been successfully logged in and the session is issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          },
          "401": {
            "description": "The provided credential is not valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Retrieve the information about currently logged in user.",
        "operationId": "me",
        "responses": {
          "200": {
            "description": "The user has been successfully logged in and the session is issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_MeResponse"
                }
              }
            }
          },
          "401": {
            "description": "The user is not logged in",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      }
    },
    "/photos": {
      "get": {
        "summary": "Get registered photos' list",
        "operationId": "get_photos_list",
        "parameters": [
          {
            "name": "cursor",
            "in": "query",
            "description": "The pagination cursor - retrieves from beginning",
            "required": false,
            "schema": {
              "type": ["string", "null"]
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "the default is 50",
            "required": false,
            "schema": {
              "type": ["integer", "null"],
              "format": "int32",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The list of images.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_GetPhotosListResponse"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Registers a new photo",
        "description": "Upload a photo payload and register. This triggers the image processing.\nNote that the response from this endpoint does not guarantee (and practically does not mean)\nthat the image has been generated. However representative_rgb is available, and the client can\nuse this value to show the placeholder for the uploaded photo, until the image is being\nprocessed.\n\nYou need to be logged in to use this endpoint.",
        "operationId": "new_photo",
        "requestBody": {
          "content": {
            "application/octet-stream": {
              "schema": {
                "$ref": "#/components/schemas/BinaryBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "The photo was registered and the image processing was queued.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_NewPhotoResponse"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          },
          "409": {
            "description": "There already was a photo registered with the matching hash",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        },
        "security": [
          {
            "session_header": []
          },
          {
            "session_cookie": []
          }
        ]
      }
    },
    "/photos/by-hashes": {
      "post": {
        "summary": "Get photos list by hashes list",
        "description": "Retrieves the list of photos from the list of hashes.\nYou need to be logged in to use this endpoint.",
        "operationId": "get_photos_list_by_hashes_list",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetPhotosListByHashesListParam"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Found photos. If no photo is found, the endpoint will return 200 OK with an empty array.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_GetPhotosListByHashesListResponse"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        },
        "security": [
          {
            "session_header": []
          },
          {
            "session_cookie": []
          }
        ]
      }
    },
    "/photos/sync/{name}": {
      "post": {
        "summary": "A new field",
        "description": "This is a new field. This initially returns implemented error.",
        "operationId": "sync",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityName"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The photo was successfully synchronized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_SyncResponse"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      }
    },
    "/photos/{photo_id}": {
      "get": {
        "summary": "Get a photo's meta",
        "operationId": "get_photo_meta",
        "parameters": [
          {
            "name": "photo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A found photo's metadata information.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_GetPhotoMetaResponse"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "A new field",
        "description": "This is a new field. This initially returns implemented error.",
        "operationId": "delete",
        "parameters": [
          {
            "name": "photo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "The photo has been removed from the Iris"
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          },
          "404": {
            "description": "The photo with the same ID is not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        },
        "security": [
          {
            "session_header": []
          },
          {
            "session_cookie": []
          }
        ]
      }
    },
    "/photos/{photo_id}/images": {
      "put": {
        "summary": "Reprocess the photo",
        "description": "Reprocess the photos. This fills up the missing images.\nYou need to be logged in to use this endpoint.",
        "operationId": "reprocess",
        "parameters": [
          {
            "name": "photo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "The photo had unprocessed image(s) and was created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_ReprocessResponse"
                }
              }
            }
          },
          "204": {
            "description": "All defined images were already creted"
          }
        },
        "security": [
          {
            "session_header": []
          },
          {
            "session_cookie": []
          }
        ]
      }
    },
    "/photos/{photo_id}/images/{image_id}": {
      "get": {
        "summary": "Get actual image",
        "description": "Retrieves the actual image binary payload.",
        "operationId": "get_image",
        "parameters": [
          {
            "name": "photo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "image_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The photo/image is found and the image payload is returned.",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "$ref": "#/components/schemas/BinaryBody"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BinaryBody": {
        "type": "string",
        "format": "binary",
        "example": "<Binary Data>"
      },
      "ClientError": {
        "type": "object",
        "required": ["status", "reason"],
        "properties": {
          "reason": {
            "type": "string",
            "example": "The value was invalid..."
          },
          "status": {
            "type": "string",
            "example": "error"
          }
        }
      },
      "EntityName": {
        "type": "string"
      },
      "GetPhotoMetaResponse": {
        "type": "object",
        "required": ["photo"],
        "properties": {
          "photo": {
            "$ref": "#/components/schemas/PhotoScheme"
          }
        }
      },
      "GetPhotosListByHashesListParam": {
        "type": "object",
        "required": ["hashes"],
        "properties": {
          "hashes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Hashes to look up.",
            "example": [
              "2653cb6500059d0316f40d0d24b7a11ace792a03eeab5b5e183275443e230612",
              "cb9e7fd9ead80d775c9cbe0fe5202a1f3202bcde6a9da92e54bc57a6e7b8931e"
            ],
            "maxItems": 100,
            "minItems": 1
          }
        }
      },
      "GetPhotosListByHashesListResponse": {
        "type": "object",
        "required": ["photos"],
        "properties": {
          "photos": {
            "type": "object",
            "description": "The map of found hashes and corresponding photos.\nNote that this map does not necessarily include all hashes specified,\nas not found hashes will not be included.",
            "additionalProperties": {
              "$ref": "#/components/schemas/PhotoReferenceSchema"
            },
            "propertyNames": {
              "type": "string"
            }
          }
        }
      },
      "GetPhotosListResponse": {
        "type": "object",
        "required": ["total_count", "photos"],
        "properties": {
          "next_cursor": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Identifier"
              }
            ]
          },
          "photos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PhotoReferenceSchema"
            }
          },
          "total_count": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "Identifier": {
        "type": "string",
        "examples": ["202604-01ARZ3NDEKTSV4RRFFQ69G5FAV"]
      },
      "ImageMetaScheme": {
        "type": "object",
        "required": ["ext", "mime", "width", "height"],
        "properties": {
          "ext": {
            "type": "string",
            "example": "jpg"
          },
          "height": {
            "type": "integer",
            "format": "int32",
            "example": 1080,
            "minimum": 0
          },
          "mime": {
            "type": "string",
            "example": "image/jpeg"
          },
          "width": {
            "type": "integer",
            "format": "int32",
            "example": 1920,
            "minimum": 0
          }
        }
      },
      "LoginBody": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "password": {
            "type": "string"
          },
          "username": {
            "$ref": "#/components/schemas/EntityName"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "required": ["session_key"],
        "properties": {
          "session_key": {
            "type": "string"
          }
        }
      },
      "MeResponse": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "$ref": "#/components/schemas/EntityName"
          }
        }
      },
      "NewPhotoResponse": {
        "type": "object",
        "required": ["photo"],
        "properties": {
          "photo": {
            "$ref": "#/components/schemas/PhotoScheme"
          }
        }
      },
      "PhotoReferenceSchema": {
        "type": "object",
        "required": [
          "id",
          "year",
          "month",
          "original_sha256",
          "images",
          "tags",
          "shot_time",
          "representative_color"
        ],
        "properties": {
          "federator": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/EntityName"
              }
            ]
          },
          "id": {
            "$ref": "#/components/schemas/Identifier"
          },
          "images": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/ImageMetaScheme"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "month": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "original_sha256": {
            "type": "string"
          },
          "representative_color": {
            "type": "string"
          },
          "shot_time": {
            "type": "string"
          },
          "tags": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "year": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "PhotoScheme": {
        "type": "object",
        "required": [
          "id",
          "original_sha256",
          "images",
          "tags",
          "shot_datetime",
          "representative_color",
          "properties"
        ],
        "properties": {
          "federator": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/EntityName"
              }
            ]
          },
          "id": {
            "$ref": "#/components/schemas/Identifier",
            "description": "Identifier assigned to the created photo."
          },
          "images": {
            "type": "object",
            "description": "The list of identifiers assigned to the specified images.\nThe image ID is used to upload the actual image later.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ImageMetaScheme"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "original_sha256": {
            "type": "string",
            "description": "The hexadecimal representation of SHA256 hash.",
            "example": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
            "maxLength": 64,
            "minLength": 64
          },
          "properties": {
            "$ref": "#/components/schemas/PropertiesSchema"
          },
          "representative_color": {
            "type": "string",
            "example": "#123456"
          },
          "shot_datetime": {
            "type": "string"
          },
          "tags": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "propertyNames": {
              "type": "string"
            }
          }
        }
      },
      "PropertiesSchema": {
        "type": "object",
        "required": ["machine"],
        "properties": {
          "f_number": {
            "type": ["number", "null"],
            "format": "double",
            "example": 5.4
          },
          "focal": {
            "type": ["number", "null"],
            "format": "double",
            "example": 50.0
          },
          "gps_lat_lng": {
            "type": ["array", "null"],
            "items": {
              "type": "number",
              "format": "double"
            },
            "example": [36.123456, 138.123456],
            "maxItems": 2,
            "minItems": 2
          },
          "iso": {
            "type": ["integer", "null"],
            "format": "int64",
            "example": 160,
            "minimum": 0
          },
          "lens": {
            "type": ["string", "null"],
            "example": "SIGMA"
          },
          "machine": {
            "type": "string",
            "example": "X-T4"
          },
          "shutter_speed": {
            "type": ["number", "null"],
            "format": "float",
            "example": 400
          },
          "shutter_speed_controlled": {
            "type": ["boolean", "null"],
            "example": true
          }
        }
      },
      "ReprocessResponse": {
        "default": null
      },
      "SuccessfulResponse_GetPhotoMetaResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object",
            "required": ["photo"],
            "properties": {
              "photo": {
                "$ref": "#/components/schemas/PhotoScheme"
              }
            }
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_GetPhotosListByHashesListResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object",
            "required": ["photos"],
            "properties": {
              "photos": {
                "type": "object",
                "description": "The map of found hashes and corresponding photos.\nNote that this map does not necessarily include all hashes specified,\nas not found hashes will not be included.",
                "additionalProperties": {
                  "$ref": "#/components/schemas/PhotoReferenceSchema"
                },
                "propertyNames": {
                  "type": "string"
                }
              }
            }
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_GetPhotosListResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object",
            "required": ["total_count", "photos"],
            "properties": {
              "next_cursor": {
                "oneOf": [
                  {
                    "type": "null"
                  },
                  {
                    "$ref": "#/components/schemas/Identifier"
                  }
                ]
              },
              "photos": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PhotoReferenceSchema"
                }
              },
              "total_count": {
                "type": "integer",
                "format": "int32",
                "minimum": 0
              }
            }
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_LoginResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object",
            "required": ["session_key"],
            "properties": {
              "session_key": {
                "type": "string"
              }
            }
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_MeResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "$ref": "#/components/schemas/EntityName"
              }
            }
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_NewPhotoResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object",
            "required": ["photo"],
            "properties": {
              "photo": {
                "$ref": "#/components/schemas/PhotoScheme"
              }
            }
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_ReprocessResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "default": null
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_SyncResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object"
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SyncResponse": {
        "type": "object"
      }
    },
    "securitySchemes": {
      "session_cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session_id"
      },
      "session_header": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
