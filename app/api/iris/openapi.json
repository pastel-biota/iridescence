{
  "openapi": "3.1.0",
  "info": {
    "title": "utoipa-axum",
    "description": "Utoipa's axum bindings for seamless integration for the two",
    "contact": {
      "name": "Juha Kukkonen",
      "email": "juha7kukkonen@gmail.com"
    },
    "license": {
      "name": "MIT OR Apache-2.0",
      "identifier": "MIT OR Apache-2.0"
    },
    "version": "0.2.0"
  },
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Get a photo's meta",
        "description": "This is a new field. This initially returns implemented error.",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/octet-stream": {
              "schema": {
                "$ref": "#/components/schemas/LoginBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "The photo was registered and ready for image upload.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      }
    },
    "/federation/health": {
      "get": {
        "summary": "Get a photo's meta",
        "description": "This is a new field. This initially returns implemented error.",
        "operationId": "ping",
        "responses": {
          "200": {
            "description": "The photo was registered and ready for image upload.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_HealthResponse"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      }
    },
    "/federation/photos": {
      "get": {
        "summary": "Get a photo's meta",
        "description": "This is a new field. This initially returns implemented error.",
        "operationId": "list",
        "responses": {
          "200": {
            "description": "The photo was registered and ready for image upload.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_ListFederatedPhotoResponse"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      }
    },
    "/photos": {
      "get": {
        "summary": "Get the list of images.",
        "operationId": "get_images_list",
        "parameters": [
          {
            "name": "cursor",
            "in": "query",
            "description": "The pagination cursor - retrieves from beginning",
            "required": false,
            "schema": {
              "type": ["string", "null"]
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "the default is 50",
            "required": false,
            "schema": {
              "type": ["integer", "null"],
              "format": "int32",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The photo was registered and ready for image upload.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_GetImagesListResponse"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Registers a new photo",
        "description": "Register a new photo, and prepare for the upload for the actual image.",
        "operationId": "new_photo",
        "requestBody": {
          "content": {
            "application/octet-stream": {
              "schema": {
                "$ref": "#/components/schemas/BinaryBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "The photo was registered and ready for image upload.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_NewPhotoResponse"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          },
          "409": {
            "description": "There already was a photo registered with the matching hash",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      }
    },
    "/photos/by-hashes": {
      "post": {
        "summary": "Get photos list by hashes list",
        "description": "Retrieves the list of photos from the list of hashes.",
        "operationId": "get_photos_list_by_hashes_list",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetPhotosListByHashesListParam"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "The photo was registered and ready for image upload.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_GetPhotosListByHashesListResponse"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      }
    },
    "/photos/{photo_id}": {
      "get": {
        "summary": "Get a photo's meta",
        "description": "This is a new field. This initially returns implemented error.",
        "operationId": "get_photo_meta",
        "parameters": [
          {
            "name": "photo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The photo was registered and ready for image upload.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_GetPhotoMetaResponse"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      }
    },
    "/photos/{photo_id}/images": {
      "put": {
        "summary": "Reprocess the photos. This fills up the missing images.",
        "operationId": "reprocess",
        "parameters": [
          {
            "name": "photo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "The photo had unprocessed image(s) and was created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessfulResponse_ReprocessResponse"
                }
              }
            }
          },
          "204": {
            "description": "All defined images were already creted"
          }
        }
      }
    },
    "/photos/{photo_id}/images/{image_id}": {
      "get": {
        "summary": "Get actual image",
        "description": "Retrieves the actual image binary payload.",
        "operationId": "get_image",
        "parameters": [
          {
            "name": "photo_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "image_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The photo/image is found and the image payload is returned.",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "$ref": "#/components/schemas/BinaryBody"
                }
              }
            }
          },
          "400": {
            "description": "The parameter/body was invalid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BinaryBody": {
        "type": "string",
        "format": "binary"
      },
      "ClientError": {
        "type": "object",
        "required": ["status", "reason"],
        "properties": {
          "reason": {
            "type": "string",
            "example": "The value was invalid..."
          },
          "status": {
            "type": "string",
            "example": "error"
          }
        }
      },
      "GetImagesListResponse": {
        "type": "object",
        "required": ["total_count", "photos"],
        "properties": {
          "next_cursor": {
            "type": ["string", "null"]
          },
          "photos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PhotoReferenceSchema"
            }
          },
          "total_count": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "GetPhotoMetaResponse": {
        "type": "object",
        "required": ["photo"],
        "properties": {
          "photo": {
            "$ref": "#/components/schemas/PhotoScheme"
          }
        }
      },
      "GetPhotosListByHashesListParam": {
        "type": "object",
        "required": ["hashes"],
        "properties": {
          "hashes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Hashes to look up.",
            "example": [
              "2653cb6500059d0316f40d0d24b7a11ace792a03eeab5b5e183275443e230612",
              "cb9e7fd9ead80d775c9cbe0fe5202a1f3202bcde6a9da92e54bc57a6e7b8931e"
            ],
            "maxItems": 100,
            "minItems": 1
          }
        }
      },
      "GetPhotosListByHashesListResponse": {
        "type": "object",
        "required": ["photos"],
        "properties": {
          "photos": {
            "type": "object",
            "description": "The map of found hashes and corresponding photos.\nNote that this map does not necessarily include all hashes specified,\nas not found hashes will not be included.",
            "additionalProperties": {
              "$ref": "#/components/schemas/PhotoReferenceSchema"
            },
            "propertyNames": {
              "type": "string"
            }
          }
        }
      },
      "HealthResponse": {
        "type": "object"
      },
      "ImageMetaScheme": {
        "type": "object",
        "required": ["ext", "mime", "width", "height"],
        "properties": {
          "ext": {
            "type": "string",
            "example": "jpg"
          },
          "height": {
            "type": "integer",
            "format": "int32",
            "example": 1080,
            "minimum": 0
          },
          "mime": {
            "type": "string",
            "example": "image/jpeg"
          },
          "width": {
            "type": "integer",
            "format": "int32",
            "example": 1920,
            "minimum": 0
          }
        }
      },
      "ListFederatedPhotoResponse": {
        "type": "object",
        "required": ["photos"],
        "properties": {
          "photos": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "LoginBody": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "password": {
            "$ref": "#/components/schemas/Password"
          },
          "username": {
            "type": "string"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "required": ["session_key"],
        "properties": {
          "session_key": {
            "type": "string"
          }
        }
      },
      "NewPhotoResponse": {
        "type": "object",
        "required": ["photo"],
        "properties": {
          "photo": {
            "$ref": "#/components/schemas/PhotoScheme"
          }
        }
      },
      "Password": {
        "type": "string"
      },
      "PhotoReferenceSchema": {
        "type": "object",
        "required": [
          "id",
          "year",
          "month",
          "original_sha256",
          "images",
          "shot_time",
          "representative_color"
        ],
        "properties": {
          "federator": {
            "type": ["string", "null"]
          },
          "id": {
            "type": "string"
          },
          "images": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/ImageMetaScheme"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "month": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "original_sha256": {
            "type": "string"
          },
          "representative_color": {
            "type": "string"
          },
          "shot_time": {
            "type": "string"
          },
          "year": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "PhotoScheme": {
        "type": "object",
        "required": [
          "id",
          "original_sha256",
          "images",
          "shot_datetime",
          "representative_color",
          "properties"
        ],
        "properties": {
          "federator": {
            "type": ["string", "null"]
          },
          "id": {
            "type": "string",
            "description": "Identifier assigned to the created photo.",
            "example": "202601_img_0001_jpg-01AAAA"
          },
          "images": {
            "type": "object",
            "description": "The list of identifiers assigned to the specified images.\nThe image ID is used to upload the actual image later.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ImageMetaScheme"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "original_sha256": {
            "type": "string",
            "description": "The hexadecimal representation of SHA256 hash.",
            "example": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
            "maxLength": 64,
            "minLength": 64
          },
          "properties": {
            "$ref": "#/components/schemas/PropertiesSchema"
          },
          "representative_color": {
            "type": "string",
            "example": "#123456"
          },
          "shot_datetime": {
            "type": "string"
          }
        }
      },
      "PropertiesSchema": {
        "type": "object",
        "required": ["machine"],
        "properties": {
          "f_number": {
            "type": ["number", "null"],
            "format": "double",
            "example": 5.4
          },
          "focal": {
            "type": ["number", "null"],
            "format": "double",
            "example": 50.0
          },
          "gps_lat_lng": {
            "type": ["array", "null"],
            "items": {
              "type": "number",
              "format": "double"
            },
            "example": [36.123456, 138.123456],
            "maxItems": 2,
            "minItems": 2
          },
          "iso": {
            "type": ["integer", "null"],
            "format": "int64",
            "example": 160,
            "minimum": 0
          },
          "lens": {
            "type": ["string", "null"],
            "example": "SIGMA"
          },
          "machine": {
            "type": "string",
            "example": "X-T4"
          },
          "shutter_speed": {
            "type": ["number", "null"],
            "format": "float",
            "example": 400
          },
          "shutter_speed_controlled": {
            "type": ["boolean", "null"],
            "example": true
          }
        }
      },
      "ReprocessResponse": {
        "default": null
      },
      "SuccessfulResponse_GetImagesListResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object",
            "required": ["total_count", "photos"],
            "properties": {
              "next_cursor": {
                "type": ["string", "null"]
              },
              "photos": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PhotoReferenceSchema"
                }
              },
              "total_count": {
                "type": "integer",
                "format": "int32",
                "minimum": 0
              }
            }
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_GetPhotoMetaResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object",
            "required": ["photo"],
            "properties": {
              "photo": {
                "$ref": "#/components/schemas/PhotoScheme"
              }
            }
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_GetPhotosListByHashesListResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object",
            "required": ["photos"],
            "properties": {
              "photos": {
                "type": "object",
                "description": "The map of found hashes and corresponding photos.\nNote that this map does not necessarily include all hashes specified,\nas not found hashes will not be included.",
                "additionalProperties": {
                  "$ref": "#/components/schemas/PhotoReferenceSchema"
                },
                "propertyNames": {
                  "type": "string"
                }
              }
            }
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_HealthResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object"
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_ListFederatedPhotoResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object",
            "required": ["photos"],
            "properties": {
              "photos": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_LoginResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object",
            "required": ["session_key"],
            "properties": {
              "session_key": {
                "type": "string"
              }
            }
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_NewPhotoResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "type": "object",
            "required": ["photo"],
            "properties": {
              "photo": {
                "$ref": "#/components/schemas/PhotoScheme"
              }
            }
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      },
      "SuccessfulResponse_ReprocessResponse": {
        "type": "object",
        "required": ["status", "response"],
        "properties": {
          "response": {
            "default": null
          },
          "status": {
            "type": "string",
            "example": "okay"
          }
        }
      }
    }
  }
}
